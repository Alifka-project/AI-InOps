# Base URL of the FastAPI backend (no trailing slash).
#
# Leave UNSET in production: the app then defaults to the same-origin path the
# platform mounts the backend under ("/_/backend", per deploy.json). Set it only
# when the backend is on a different origin (e.g. a separate Render service).
#
# Local dev (separate uvicorn on :8000):
NEXT_PUBLIC_API_URL=http://localhost:8000
